# Copia este archivo a .env y rellena los valores reales.
# .env NUNCA debe subirse al repositorio (ya está en .gitignore).

# Base de datos PostgreSQL
DB_URL=jdbc:postgresql://<host>:<port>/<nombre_db>
DB_USER=postgres
DB_PASSWORD=

# JWT — genera un valor con: node -e "require('crypto').randomBytes(32).toString('hex') |> console.log"
JWT_SECRET=
